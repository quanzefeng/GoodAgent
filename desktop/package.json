{
  "name": "goodagent-desktop",
  "version": "1.0.1",
  "description": "GoodAgent Desktop — Electron GUI wrapper",
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist:win": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg",
    "dist:linux": "electron-builder --linux deb AppImage",
    "dist:all": "electron-builder --win nsis --mac dmg --linux deb AppImage",
    "lint": "eslint *.mjs core/*.mjs",
    "lint:fix": "eslint --fix *.mjs core/*.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.goodagent.desktop",
    "productName": "GoodAgent",
    "asar": true,
    "files": [
      "main.mjs",
      "preload.cjs",
      "renderer/**"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "cli-dist"
      }
    ],
    "icon": "icon.ico",
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "artifactName": "GoodAgent-${version}-Windows-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "artifactName": "GoodAgent-${version}-macOS-${arch}.${ext}",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["deb", "AppImage"],
      "icon": "icon.png",
      "artifactName": "GoodAgent-${version}-Linux-${arch}.${ext}",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "qrcode": "^1.5.4"
  }
}
