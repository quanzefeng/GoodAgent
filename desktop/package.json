{
  "name": "aideagent-desktop",
  "version": "1.0.12",
  "description": "AideAgent Desktop — Electron GUI wrapper",
  "repository": "https://github.com/quanzefeng/AideAgent",
  "author": "quanzefeng <quanzefeng@gmail.com>",
  "homepage": "https://github.com/quanzefeng/AideAgent",
  "license": "Apache-2.0",
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "start": "cross-env ELECTRON_DISABLE_SANDBOX=1 electron .",
    "dev": "electron . --dev",
    "dist:win": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg",
    "dist:linux": "electron-builder --linux deb AppImage",
    "dist:all": "electron-builder --win nsis --mac dmg --linux deb AppImage",
    "lint": "eslint *.mjs core/*.mjs",
    "lint:fix": "eslint --fix *.mjs core/*.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "download-model": "node scripts/download-model.mjs",
    "postinstall": "node scripts/download-model.mjs"
  },
  "publish": {
    "provider": "github",
    "owner": "quanzefeng",
    "repo": "AideAgent"
  },
  "build": {
    "appId": "com.aideagent.desktop",
    "productName": "AideAgent",
    "asar": true,
    "asarUnpack": [
      "node_modules/onnxruntime-node/**",
      "node_modules/sharp/**"
    ],
    "files": [
      "*.mjs",
      "preload.cjs",
      "renderer/**",
      "core/**",
      "search-engine/**"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "cli-dist"
      },
      {
        "from": "models",
        "to": "models"
      }
    ],
    "icon": "icon.ico",
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "artifactName": "AideAgent-${version}-Windows-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "artifactName": "AideAgent-${version}-macOS-${arch}.${ext}",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "icon": "icon.png",
      "artifactName": "AideAgent-${version}-Linux-${arch}.${ext}",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.4"
  }
}
