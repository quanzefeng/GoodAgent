{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "noImplicitAny": false,
    "allowJs": true,
    "checkJs": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["core/**/*", "*.mjs", "preload.cjs", "renderer/**/*"],
  "exclude": ["node_modules", "test/**", "test-results/**", "playwright-report/**", "dist/**", "models/**", "release/**", "scripts/**"]
}
